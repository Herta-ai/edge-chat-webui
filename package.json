    "defu": "^6.1.4",
    "naive-ui": "^2.44.1",
    "nanoid": "^5.1.7",
    "nprogress": "^0.2.0",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "vue": "^3.6.0-beta.8",
    "vue-i18n": "^11.3.0",
    "vue-router": "^5.0.4",
    "xsai-transformers": "^0.0.11"
