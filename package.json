    "@types/nprogress": "0.2.3",
    "@unocss/eslint-plugin": "^66.6.7",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vue/tsconfig": "^0.9.1",
    "consola": "^3.4.2",
    "eslint": "^10.1.0",
    "eslint-plugin-format": "^2.0.1",
    "eslint-plugin-import-x": "^4.16.2",
