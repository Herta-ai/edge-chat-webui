{
  "name": "edge-chat-webui",
  "type": "module",
  "version": "2.1.0",
  "description": "构建在浏览器端的下一代 AI 智能体与工作流编排 WebUI",
  "license": "MIT",
  "homepage": "https://github.com/Herta-ai/edge-chat-webui",
  "repository": {
    "url": "https://github.com/Herta-ai/edge-chat-webui.git"
  },
  "bugs": {
    "url": "https://github.com/Herta-ai/edge-chat-webui/issues"
  },
  "engines": {
    "bun": ">=1.3.7"
  },
  "scripts": {
    "build": "vite build --mode prod",
