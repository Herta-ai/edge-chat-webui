    "@xsai/model": "^0.4.0-beta.9",
    "@xsai/shared": "^0.4.0-beta.9",
    "@xsai/shared-chat": "0.4.0-beta.4",
    "@xsai/stream-object": "^0.4.0-beta.9",
    "@xsai/stream-text": "0.4.0-beta.4",
    "@xsai/tool": "^0.4.0-beta.9",
    "@xsai/utils-chat": "^0.4.0-beta.9",
    "xsai": "^0.4.0-beta.9",
    "xsschema": "^0.4.0-beta.9"
